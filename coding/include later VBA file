Sub CombineCsvFiles_Revised()

'updated by MelCompton, revised for stability
'This version fixes a loop boundary error and uses OpenText for proper delimiter handling.

    Dim xFilesToOpen As Variant
    Dim I As Long 'Use Long for integer variables that can get large, it's good practice in VBA
    Dim xWb As Workbook
    Dim xTempWb As Workbook
    Dim xDelimiter As String
    Dim xScreen As Boolean

    On Error GoTo ErrHandler

    xScreen = Application.ScreenUpdating
    Application.ScreenUpdating = False

    'Set the delimiter
    xDelimiter = "|"

    'Prompt the user to select files
    xFilesToOpen = Application.GetOpenFilename("Text Files (*.csv),*.csv", , "MelCompton VBA for Excel", , True)

    'Check if the user cancelled the dialog
    If Not IsArray(xFilesToOpen) Then
        MsgBox "No files were selected.", vbInformation, "MelCompton VBA for Excel"
        GoTo ExitHandler
    End If

    
'--- Process the first file ---
    I = LBound(xFilesToOpen) 'Use LBound for robustness
    'Open the first file, specifying the delimiter
    Set xTempWb = Workbooks.OpenText(Filename:=xFilesToOpen(I), DataType:=xlDelimited, Other:=True, OtherChar:=xDelimiter)
    
    'Copy the first sheet to a new workbook
    xTempWb.Sheets(1).Copy
    Set xWb = Application.ActiveWorkbook 'The new workbook is now the active one
    xWb.Sheets(1).Name = xTempWb.Name 'Rename the sheet to the file name
    xTempWb.Close SaveChanges:=False

    '--- Loop through the rest of the files ---
    'The loop should go from the second file to the last file
    For I = LBound(xFilesToOpen) + 1 To UBound(xFilesToOpen)
        Set xTempWb = Workbooks.OpenText(Filename:=xFilesToOpen(I), DataType:=xlDelimited, Other:=True, OtherChar:=xDelimiter)
        
        'Move the sheet from the temporary workbook to the combined workbook
        xTempWb.Sheets(1).Move After:=xWb.Sheets(xWb.Sheets.Count)
        xWb.Sheets(xWb.Sheets.Count).Name = xTempWb.Name 'Rename the moved sheet
        
        'The temp workbook will close automatically since its only sheet was moved
    Next I

ExitHandler:
    Application.ScreenUpdating = xScreen
    Set xWb = Nothing
    Set xTempWb = Nothing
    Exit Sub

ErrHandler:
    MsgBox "An error occurred: " & Err.Description, vbCritical, "MelCompton VBA for Excel"
    Resume ExitHandler

End Sub
Summary of Changes
Correct Loop: The Do While loop was replaced with a For I = LBound(xFilesToOpen) + 1 To UBound(xFilesToOpen) loop. This ensures that every file from the second to the very last one is processed.

Robust File Opening: Switched to Workbooks.OpenText() and used the Other and OtherChar parameters to correctly handle the | delimiter.

Sheet Naming: Added code to rename the sheets in the combined workbook to match the names of the original CSV files, which makes the final result more organized.

Better Variable Typing: Changed Dim I As Integer to Dim I As Long which is a best practice in modern VBA to avoid potential overflow errors.

Array Check: Changed TypeName(xFilesToOpen) = "Boolean" to Not IsArray(xFilesToOpen) which is a more robust way to check if the user canceled the file selection dialog.

By implementing these changes, your script should run without crashing and will correctly combine all selected CSV files.


